# Copy this file to .env and fill in your credentials.
# Never commit .env to version control (it is gitignored).

# ─── SMTP credentials ───────────────────────────────────────────────
EMAIL_HOST=mail.yourdomain.com
EMAIL_PORT=587
EMAIL_SECURE=false          # true for port 465 (SSL), false for 587 (STARTTLS)
EMAIL_USER=no-reply@yourdomain.com
EMAIL_PASS=your-mailbox-password

# ─── Where contact-form emails are delivered ────────────────────────
EMAIL_TO=customer.service@everlastwellness.com

# ─── Server port ────────────────────────────────────────────────────
PORT=5000
